<nav class="tel-quick-filters" data-component="tel-quick-filters">
  <ul class="tel-quick-filters__list" role="list">

    {% if params.heading %}
      <span class="tel-quick-filters__list-heading">{{ params.heading }}</span>
    {% endif %}

    {# The "All" filter button #}
    <li class="tel-quick-filters__list-item">
      {% set isAllActive = not params.activeTag %}
      <a
        href="{{ params.allHref | default('#') }}"
        class="tel-quick-filters__button{% if isAllActive %} tel-quick-filters__button--active{% endif %}"
        {% if isAllActive %}aria-current="true"{% endif %}
      >
        <span>All</span>
      </a>
    </li>

    {# Loop through the tags provided in params #}
    {% for tag in params.tags %}
      {% set label = tag.label or tag %}
      {% set value = tag.value or tag %}
      {% set isActive = params.activeTag and params.activeTag == value %}

      <li class="tel-quick-filters__list-item">
        <a
          href="{{ tag.href | default('#') }}"
          class="tel-quick-filters__button{% if isActive %} tel-quick-filters__button--active{% endif %}"
          {% if isActive %}aria-current="true"{% endif %}
          data-filter-value="{{ value }}"
        >
          <span>{{ label }}</span>
        </a>
      </li>
    {% endfor %}

  </ul>
</nav>
