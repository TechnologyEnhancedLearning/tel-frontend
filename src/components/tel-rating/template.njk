{% from "../tel-definition-list/macro.njk" import definitionList %}

{% macro rating(type='star', progress, additionalClasses='') %}
<div class="tel-rating tel-rating--{{type}} {{additionalClasses}}">
  <div class="tel-rating__container">
    <div class="tel-rating__progress">
      {% if type == 'star' %}
      <svg viewBox="0 0 576 512" width="100" title="star">
        <path d="M259.3 17.8L194 150.2 47.9 171.5c-26.2 3.8-36.7 36.1-17.7 54.6l105.7 103-25 145.5c-4.5 26.3 23.2 46 46.4 33.7L288 439.6l130.7 68.7c23.2 12.2 50.9-7.4 46.4-33.7l-25-145.5 105.7-103c19-18.5 8.5-50.8-17.7-54.6L382 150.2 316.7 17.8c-11.7-23.6-45.6-23.9-57.4 0z" />
      </svg><svg viewBox="0 0 576 512" width="100" title="star">
        <path d="M259.3 17.8L194 150.2 47.9 171.5c-26.2 3.8-36.7 36.1-17.7 54.6l105.7 103-25 145.5c-4.5 26.3 23.2 46 46.4 33.7L288 439.6l130.7 68.7c23.2 12.2 50.9-7.4 46.4-33.7l-25-145.5 105.7-103c19-18.5 8.5-50.8-17.7-54.6L382 150.2 316.7 17.8c-11.7-23.6-45.6-23.9-57.4 0z" />
      </svg><svg viewBox="0 0 576 512" width="100" title="star">
        <path d="M259.3 17.8L194 150.2 47.9 171.5c-26.2 3.8-36.7 36.1-17.7 54.6l105.7 103-25 145.5c-4.5 26.3 23.2 46 46.4 33.7L288 439.6l130.7 68.7c23.2 12.2 50.9-7.4 46.4-33.7l-25-145.5 105.7-103c19-18.5 8.5-50.8-17.7-54.6L382 150.2 316.7 17.8c-11.7-23.6-45.6-23.9-57.4 0z" />
      </svg><svg viewBox="0 0 576 512" width="100" title="star">
        <path d="M259.3 17.8L194 150.2 47.9 171.5c-26.2 3.8-36.7 36.1-17.7 54.6l105.7 103-25 145.5c-4.5 26.3 23.2 46 46.4 33.7L288 439.6l130.7 68.7c23.2 12.2 50.9-7.4 46.4-33.7l-25-145.5 105.7-103c19-18.5 8.5-50.8-17.7-54.6L382 150.2 316.7 17.8c-11.7-23.6-45.6-23.9-57.4 0z" />
      </svg><svg viewBox="0 0 576 512" width="100" title="star">
        <path d="M259.3 17.8L194 150.2 47.9 171.5c-26.2 3.8-36.7 36.1-17.7 54.6l105.7 103-25 145.5c-4.5 26.3 23.2 46 46.4 33.7L288 439.6l130.7 68.7c23.2 12.2 50.9-7.4 46.4-33.7l-25-145.5 105.7-103c19-18.5 8.5-50.8-17.7-54.6L382 150.2 316.7 17.8c-11.7-23.6-45.6-23.9-57.4 0z" />
      </svg>
      {% endif %}

      <div class="tel-rating__completion"></div>
      <div class="tel-rating__cover" style="width: {{100 - progress}}%;"></div>
    </div>
  </div>
  {% if type == 'star' %}
  <div class="tel-rating_description">{{ (5 / 100 * progress) | int }} out of 5 (<span class="tel-rating__link"><a href="#" >8 ratings</a> </span>)</div>
  {% else %}
  {{ definitionList({
    additionalClasses: "tel-learning-listing__key-info__information__dl",
    groups: [
      {
        title: "Progress:",
        descriptions: [progress + "% complete"]
      }],
    size: "small"
  })
  }}
  {% endif %}
</div>
{% endmacro %}
